AIREST_PORT=3300
AIREST_API_KEY=replace-me
# Leave blank or omit to disable x-api-key checks locally:
# AIREST_API_KEY=
# Optional. When unset, aiREST loads YAML from the current working directory (recursive by default).
# Paths in this file are relative to the directory you run `airest` from.
# AIREST_API_DIR=./examples
AIREST_LOG_LEVEL=info

# OpenTelemetry (optional; build with --features otel)
AIREST_OTEL_ENABLED=false
AIREST_OTEL_METRICS=false
AIREST_OTEL_SAMPLE_RATIO=1.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Semantic / exact cache (in-memory by default; ~50 signatures per endpoint)
AIREST_CACHE_ENABLED=false
AIREST_CACHE_MAX_ENTRIES=50
# Optional on-disk persistence (redb). Leave unset for in-memory only.
# AIREST_CACHE_STORE_PATH=.airest/cache/airest.redb
# Embedder: hash (offline, default) or openai (requires OPENAI_API_KEY)
AIREST_CACHE_EMBED_PROVIDER=hash
AIREST_CACHE_EMBED_MODEL=text-embedding-3-small

# JWT verification (when endpoints use auth.type: jwt)
AIREST_JWT_JWKS_URL=
AIREST_JWT_ISSUER=
AIREST_JWT_AUDIENCE=

# OAuth2 token introspection (auth.type: oauth2Introspect)
AIREST_OAUTH2_INTROSPECTION_URL=
AIREST_OAUTH2_CLIENT_ID=
AIREST_OAUTH2_CLIENT_SECRET=

# JWT jti denylist (comma-separated static IDs; optional Redis set)
AIREST_JTI_DENYLIST=
# AIREST_REDIS_URL=redis://localhost:6379
# AIREST_JTI_DENYLIST_KEY=airest:jti:denylist
AIREST_HOT_RELOAD=false
AIREST_LOAD_RECURSIVE=true

# Production hardening (off by default; enable for deployed environments)
# AIREST_PRODUCTION=true
# AIREST_MAX_REQUEST_BODY_BYTES=1048576
# AIREST_REQUEST_TIMEOUT_SECS=120
# Graceful shutdown drain (off by default; enable in production)
# AIREST_GRACEFUL_SHUTDOWN=true
# AIREST_GRACEFUL_SHUTDOWN_SECS=30
# AIREST_MAX_CONCURRENT_REQUESTS=64
# AIREST_LLM_CIRCUIT_BREAKER_THRESHOLD=5
# AIREST_LLM_CIRCUIT_BREAKER_RESET_SECS=30

# OpenAI (provider: openai)
OPENAI_API_KEY=replace-me
OPENAI_BASE_URL=https://api.openai.com/v1

# Azure OpenAI (provider: azure_openai)
# AZURE_OPENAI_API_KEY=replace-me
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Anthropic (provider: anthropic)
# ANTHROPIC_API_KEY=replace-me
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_API_VERSION=2023-06-01

# Google Gemini (provider: gemini)
# GEMINI_API_KEY=replace-me
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# xAI Grok (provider: grok)
# GROK_API_KEY=replace-me
# XAI_API_KEY=replace-me
# GROK_BASE_URL=https://api.x.ai/v1

# Ollama (provider: ollama — local, no key required)
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=
